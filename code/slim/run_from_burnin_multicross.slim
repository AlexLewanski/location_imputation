function (+)readMatrix(s$ path, [string$ sep = ","])
{
	if (!fileExists(path))
		stop("readMatrix(): File not found at path " + path);
	df = readCSV(path, colNames=F, sep=sep);
	m = df.asMatrix();
	return m;
}


function(numeric) dist(numeric x, numeric y) 
{
 d = sqrt(sum((x - y)^2));
 return d;
}


function(numeric) dist_compare(numeric focal_loc, numeric loc_mat)
{

 dist_vec = float(nrow(loc_mat));
 for (i in 0:(nrow(loc_mat) - 1)) {
	 dist_vec[i] = dist(focal_loc, loc_mat[i,]);
 }
	
 return dist_vec;
}


function(logical) dist_threshold_check(numeric focal_loc, numeric loc_mat, numeric threshold)
{
 dists = dist_compare(focal_loc, loc_mat);
 return any(dists < threshold);
}


function(lifso) sample_indivs(lifso inds, integer n, numeric apo, numeric x, numeric y) 
{
	
ind_pool = inds[inds.x > x - apo & inds.x < x + apo & inds.y > y - apo & inds.y < y + apo];

if (length(ind_pool) < n) {
	return(c());
} else {
	return(sample(ind_pool, n, replace = F));
}

}


function(lifso) sample_founders(lifso inds, 
                                  numeric k_val, 
                                  integer n_vec,
                                  integer apo, 
                                  numeric x_lim, 
                                  numeric y_lim, 
                                  numeric dist_threshold)
{
 
 loc_mat = matrix(rep(0.0, k_val*2), ncol=2);
 founder_vec = c();
 for (k in 0:(k_val - 1) ) {
  if (k == 0) {
  	 indiv_sample = c();
  	 check0 = 0;
  	 while (n_vec[k] != length(indiv_sample) & check0 <= 1000)
  	 {
  	  prop_loc = c(runif(1, x_lim[0], x_lim[1]), runif(1, y_lim[0], y_lim[1]) );
  	  indiv_sample = sample_indivs(inds, n_vec[k], apo, prop_loc[0], prop_loc[1]);
  	  check0 = check0 + 1; 
  	 }
  	 
  	 if (n_vec[k] != length(indiv_sample)) {
      stop(message = 'Unable to sample indivs in 1000 attempts.');
    }
  	 
  	 founder_vec = c(founder_vec, indiv_sample);
    loc_mat[k,] = prop_loc;
    next;
  }
  
  check = 0;
  loc_check = T;
  while (check <= 2000 & loc_check) {
   prop_loc = c(runif(1, x_lim[0], x_lim[1]), runif(1, y_lim[0], y_lim[1]) );
   dist_check = dist_threshold_check(prop_loc, loc_mat[0:(k - 1),], dist_threshold); 
   
   if (!dist_check) {
     indiv_sample = sample_indivs(inds, n_vec[k], apo, prop_loc[0], prop_loc[1]);
     if (n_vec[k] != length(indiv_sample)) {
	    loc_check = T;
     } 
   }
   
   check = check + 1;
  }
 
  if (n_vec[k] != length(indiv_sample)) {
   stop(message = 'Unable to find new source location after 2000 attempts.');
  }
  
 founder_vec = c(founder_vec, indiv_sample);
 loc_mat[k,] = prop_loc;
 }
  
 output_dict = Dictionary("loc_info", repEach(0:(length(n_vec) - 1), n_vec), 
                          "location_mat", loc_mat, 
                          "founders", founder_vec);
 
 // print out default values
 catn("===========================");
 catn("Model constants: " + output_dict.serialize("pretty"));
 catn("===========================");
 return output_dict;

}



